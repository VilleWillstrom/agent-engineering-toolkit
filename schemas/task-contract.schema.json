{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/VilleWillstrom/agent-engineering-toolkit/schemas/task-contract.schema.json",
  "title": "Agent Engineering Task Contract",
  "type": "object",
  "required": ["task", "scope", "delivery", "acceptance_criteria", "validation", "review"],
  "properties": {
    "task": {
      "type": "object",
      "required": ["id", "title", "goal"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "goal": { "type": "string", "minLength": 1 }
      }
    },
    "scope": {
      "type": "object",
      "required": ["allowed_paths", "forbidden_paths"],
      "properties": {
        "allowed_paths": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "forbidden_paths": { "type": "array", "items": { "type": "string" } }
      }
    },
    "delivery": {
      "type": "object",
      "required": ["selected_worker", "branch", "max_attempts"],
      "properties": {
        "selected_worker": { "enum": ["codex-self", "claude-code"] },
        "branch": { "type": "string", "minLength": 1 },
        "max_attempts": { "type": "integer", "minimum": 1, "maximum": 5 }
      }
    },
    "acceptance_criteria": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "validation": { "type": "object" },
    "review": { "type": "object" }
  },
  "additionalProperties": true
}
